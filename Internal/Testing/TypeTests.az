package testing

test "Var Int Test" {
    var a: Int = 4
    var b = 5
    var c: Int = 0

    assert a == 4 { "a value" }
    assert a.typename == "Int" { "a typename" }
    assert a.min == -2_147_483_648 { "a min" }
    assert a.max == 2_147_483_647 { "a max" }

    assert b == 5 { "b value" }
    assert b.typename == "Int" { "b typename" }
    assert b.min == -2_147_483_648 { "b min" }
    assert b.max == 2_147_483_647 { "b max" }

    assert c == 0 { "c value" }
    assert c.typename == "Int" { "c typename" }
    assert c.min == -2_147_483_648 { "c min" }
    assert c.max == 2_147_483_647 { "c max" }
}
