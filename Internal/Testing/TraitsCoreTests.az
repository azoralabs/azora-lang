package testing

use scope std

// --- Equatable ---

test "Equatable Int" {
    fin a = 42
    fin b = 42
    fin c = 99
    assert a == b { "equal ints should be ==" }
    assert a != c { "different ints should be !=" }
}

test "Equatable Real" {
    fin a = 3.14
    fin b = 3.14
    fin c = 2.71
    assert a == b { "equal reals should be ==" }
    assert a != c { "different reals should be !=" }
}

test "Equatable String" {
    fin a = "hello"
    fin b = "hello"
    fin c = "world"
    assert a == b { "equal strings should be ==" }
    assert a != c { "different strings should be !=" }
}

test "Equatable Bool" {
    assert true == true { "true == true" }
    assert false == false { "false == false" }
    assert true != false { "true != false" }
}

// --- Comparable ---

test "Comparable Int" {
    assert 1 < 2 { "1 < 2" }
    assert 3 > 1 { "3 > 1" }
    assert !(2 < 2) { "2 is not < 2" }
}

test "Comparable Real" {
    assert 1.5 < 2.5 { "1.5 < 2.5" }
    assert 3.0 > 1.0 { "3.0 > 1.0" }
}

// --- Displayable ---

test "Displayable Int" {
    fin s = toString(42)
    assert s == "42" { "toString(42) should be 42" }
}

test "Displayable String" {
    fin s = toString("hello")
    assert s == "hello" { "toString(hello) should be hello" }
}

test "Displayable Bool" {
    assert toString(true) == "true" { "toString(true) should be true" }
    assert toString(false) == "false" { "toString(false) should be false" }
}
