module testing

// --- String built-in tests ---

test "stringLength" {
    assert stringLength("hello") == 5 { "hello has 5 chars" }
    assert stringLength("") == 0 { "empty has 0 chars" }
    assert stringLength("a") == 1 { "single char has 1" }
}

test "charAt success" {
    var c = charAt("hello", 1)
    assert c == 'e' { "index 1 of hello is e" }
}

test "charAt first" {
    var c = charAt("abc", 0)
    assert c == 'a' { "index 0 is a" }
}

test "substring" {
    assert substring("hello world", 0, 5) == "hello" { "slice first word" }
    assert substring("hello world", 6, 11) == "world" { "slice second word" }
}

test "startsWith" {
    assert startsWith("hello", "hel") == true { "starts with hel" }
    assert startsWith("hello", "xyz") == false { "does not start with xyz" }
    assert startsWith("hello", "") == true { "starts with empty" }
}

test "endsWith" {
    assert endsWith("hello", "llo") == true { "ends with llo" }
    assert endsWith("hello", "xyz") == false { "does not end with xyz" }
}

test "contains" {
    assert contains("hello world", "world") == true { "contains world" }
    assert contains("hello world", "xyz") == false { "does not contain xyz" }
    assert contains("hello", "") == true { "contains empty" }
}

test "indexOf" {
    assert indexOf("hello", "ll") == 2 { "ll at index 2" }
    assert indexOf("hello", "xyz") == -1 { "not found" }
    assert indexOf("hello", "h") == 0 { "h at index 0" }
}

test "trim" {
    assert trim("  hello  ") == "hello" { "trim whitespace" }
    assert trim("hello") == "hello" { "no whitespace to trim" }
    assert trim("   ") == "" { "all whitespace" }
}

test "toUpper" {
    assert toUpper("hello") == "HELLO" { "uppercase" }
    assert toUpper("Hello World") == "HELLO WORLD" { "mixed case" }
}

test "toLower" {
    assert toLower("HELLO") == "hello" { "lowercase" }
    assert toLower("Hello World") == "hello world" { "mixed case" }
}

test "replace" {
    assert replace("hello world", "world", "azora") == "hello azora" { "replace word" }
    assert replace("aaa", "a", "b") == "bbb" { "replace all occurrences" }
}

test "split" {
    var parts = split("a,b,c", ",")
    assert parts.length == 3 { "3 parts" }
    assert parts[0] == "a" { "first" }
    assert parts[1] == "b" { "second" }
    assert parts[2] == "c" { "third" }
}

test "split no match" {
    var parts = split("hello", ",")
    assert parts.length == 1 { "no split, 1 part" }
    assert parts[0] == "hello" { "whole string" }
}

test "toChars" {
    var chars = toChars("hi")
    assert chars.length == 2 { "2 chars" }
    assert chars[0] == 'h' { "h" }
    assert chars[1] == 'i' { "i" }
}

test "fromChars" {
    var chars: [Char] = ['a', 'z']
    var s = fromChars(chars)
    assert s == "az" { "chars to string" }
}

test "string empty check" {
    assert stringLength("") == 0 { "empty is empty" }
    assert stringLength("a") > 0 { "non-empty has positive length" }
}

// --- String interpolation ---

test "string interpolation basic" {
    fin name = "Azora"
    fin s = "Hello, ${name}!"
    assert s == "Hello, Azora!" { "interpolation" }
}

test "string interpolation expression" {
    fin x = 5
    fin s = "Result: ${x * 2}"
    assert s == "Result: 10" { "interpolation with expression" }
}

test "string interpolation multiple" {
    fin a = "hello"
    fin b = "world"
    fin s = "${a} ${b}"
    assert s == "hello world" { "multiple interpolations" }
}
