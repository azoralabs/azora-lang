package testing

use scope std

// --- pow ---

test "pow basic" {
    assert pow(2, 0) == 1 { "2^0 should be 1" }
    assert pow(2, 1) == 2 { "2^1 should be 2" }
    assert pow(2, 10) == 1024 { "2^10 should be 1024" }
    assert pow(3, 3) == 27 { "3^3 should be 27" }
}

test "pow edge cases" {
    assert pow(0, 0) == 1 { "0^0 should be 1" }
    assert pow(1, 100) == 1 { "1^100 should be 1" }
    assert pow(5, 0) == 1 { "5^0 should be 1" }
}

// --- pow with Real ---

test "pow real" {
    assert pow(2.0, 3) == 8.0 { "2.0^3 should be 8.0" }
}

// --- factorial ---

test "factorial" {
    assert factorial(0) == 1 { "0! should be 1" }
    assert factorial(1) == 1 { "1! should be 1" }
    assert factorial(5) == 120 { "5! should be 120" }
    assert factorial(10) == 3628800 { "10! should be 3628800" }
}

// --- gcd ---

test "gcd" {
    assert gcd(12, 8) == 4 { "gcd(12, 8) should be 4" }
    assert gcd(15, 5) == 5 { "gcd(15, 5) should be 5" }
    assert gcd(7, 13) == 1 { "gcd(7, 13) should be 1" }
    assert gcd(0, 5) == 5 { "gcd(0, 5) should be 5" }
}

// --- lcm ---

test "lcm" {
    assert lcm(4, 6) == 12 { "lcm(4, 6) should be 12" }
    assert lcm(3, 7) == 21 { "lcm(3, 7) should be 21" }
    assert lcm(0, 5) == 0 { "lcm(0, 5) should be 0" }
}

// --- isEven & isOdd ---

test "isEven and isOdd" {
    assert isEven(0) { "0 should be even" }
    assert isEven(4) { "4 should be even" }
    assert !isEven(3) { "3 should not be even" }
    assert isOdd(1) { "1 should be odd" }
    assert isOdd(7) { "7 should be odd" }
    assert !isOdd(8) { "8 should not be odd" }
}

// --- sum ---

test "sum" {
    var arr: [Int] = [1, 2, 3, 4, 5]
    assert sum<Int>(arr) == 15 { "sum should be 15" }
}

test "sum empty" {
    var arr: [Int] = [].fill<Int>(0)
    assert sum<Int>(arr) == 0 { "sum of empty should be 0" }
}

// --- sumReal ---

test "sumReal" {
    var arr: [Real] = [1.5, 2.5, 3.0]
    assert sumReal<Real>(arr) == 7.0 { "sumReal should be 7.0" }
}

// --- product ---

test "product" {
    var arr: [Int] = [1, 2, 3, 4]
    assert product<Int>(arr) == 24 { "product should be 24" }
}

test "product empty" {
    var arr: [Int] = [].fill<Int>(0)
    assert product<Int>(arr) == 0 { "product of empty should be 0" }
}

// --- fib ---

test "fib" {
    assert fib(0) == 0 { "fib(0) should be 0" }
    assert fib(1) == 1 { "fib(1) should be 1" }
    assert fib(2) == 1 { "fib(2) should be 1" }
    assert fib(5) == 5 { "fib(5) should be 5" }
    assert fib(10) == 55 { "fib(10) should be 55" }
}
