module testing

import std

// --- Guard ---

test "Guard get" {
    var g = Guard<Int>(value: 42)
    assert g.get() == 42 { "guard get should return 42" }
}

test "Guard read" {
    var g = Guard<Int>(value: 10)
    var seen = 0
    g.read({ v -> seen = v })
    assert seen == 10 { "guard read should see 10" }
}

test "Guard write" {
    var g = Guard<Int>(value: 5)
    g.write({ v -> v + 10 })
    assert g.get() == 15 { "guard write should update to 15" }
}

test "Guard multiple writes" {
    var g = Guard<Int>(value: 0)
    g.write({ v -> v + 1 })
    g.write({ v -> v + 1 })
    g.write({ v -> v + 1 })
    assert g.get() == 3 { "guard after 3 writes should be 3" }
}

// --- CountDownLatch ---

test "CountDownLatch construction" {
    var latch = CountDownLatch<Int>(count: 3)
    assert latch.count == 3 { "latch count should be 3" }
    assert !latch.isReached { "latch should not be reached initially" }
}

test "CountDownLatch countDown" {
    var latch = CountDownLatch<Int>(count: 2)
    latch.countDown()
    assert !latch.isReached { "latch should not be reached after 1 countDown" }
    latch.countDown()
    assert latch.isReached { "latch should be reached after 2 countDowns" }
}

// --- SpinLock ---

test "SpinLock acquire release" {
    var lock = SpinLock<Int>(_tag: 0)
    lock.acquire()
    lock.release()
    assert true { "spinlock acquire/release should not deadlock" }
}

test "SpinLock withLock" {
    var lock = SpinLock<Int>(_tag: 0)
    var counter = 0
    lock.withLock({ counter += 1 })
    assert counter == 1 { "withLock should execute action" }
}

// --- withMutex ---

test "withMutex function" {
    var m = Mutex(0)
    var value = 0
    withMutex(m, { value = 42 })
    assert value == 42 { "withMutex should execute action" }
}
