module testing

use zone std

// --- timeout ---

test "timeout completes" {
    fin result = timeout(200, { var x = 1 + 1 })
    assert result { "fast action should complete within timeout" }
}

test "timeout expires" {
    fin result = timeout<Int>(10, { suspend 500 })
    assert !result { "slow action should not complete within timeout" }
}

// --- retry ---

test "retry succeeds first try" {
    fin result = retry(3, 10, { return true })
    assert result { "retry should succeed on first try" }
}

test "retry succeeds after failures" {
    var attempt = 0
    fin result = retry<Int>(3, 10, { attempt += 1; return attempt >= 2 })
    assert result { "retry should succeed on second attempt" }
}

test "retry all fail" {
    fin result = retry(3, 10, { return false })
    assert !result { "retry should return false when all attempts fail" }
}

// --- parallel ---

test "parallel runs both" {
    var a = 0
    var b = 0
    parallel(0, { a = 1 }, { b = 2 })
    assert a == 1 { "parallel should run first action" }
    assert b == 2 { "parallel should run second action" }
}
