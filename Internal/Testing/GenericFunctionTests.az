module testing

func<T> add(a: T, b: T): T {
    return a + b
}

func<T> identityFunc(a: T): T = a

func<T> addNoReturn(a: T, b: T) {
    return a + b
}

func<T> addExprNoReturn(a: T, b: T) = a + b

test "Generic func inferred from args" {
    fin result1 = add(5, 7)
    assert result1 == 12 { "add(5, 7) should be 12" }
}

test "Generic func explicit type param" {
    fin result = add<Int>(9, -5)
    assert result == 4 { "add<Int>(9, -5) should be 4" }
}

test "Generic func with typed target" {
    fin result: Int = add(1, 3)
    assert result == 4 { "typed target add(1, 3) should be 4" }
}

test "Generic func identity" {
    fin x = identityFunc(42)
    assert x == 42 { "identity(42) should be 42" }
}

test "Generic func expression body no return type" {
    fin r = addExprNoReturn(10, 20)
    assert r == 30 { "addExprNoReturn(10, 20) should be 30" }
}

spec Numeric

impl Numeric for Int
impl Numeric for Real

type promote(t1: Type, t2: Type) {
    return if t1.rank >= t2.rank { t1 } else { t2 }
}

type promote(T: ...Type) where T.length >= 2 {
    let Result = T.0
    for Ty in T[1...] {
        Result = if Ty.rank > Result.rank { Ty } else { Result }
    }
    return Result
}

func<T1, T2> addTwo(a: T1, b: T2): promote(T1, T2)
where T1: Numeric, T2: Numeric {
    return a + b
}

func<...T> addMany(args: ...T): promote(T)
where each T: Numeric {
    var sum: ReturnType = 0 as ReturnType
    for arg in args {
        sum += arg
    }
    return sum
}

test "Generic func promote return type Int Real" {
    var r = addTwo<Int, Real>(5, 3.4)
    assert r.typename == "Real" { "promote(Int, Real) should be Real" }
}

test "Generic func variadic promote return type" {
    var x = addMany(2, 3.4, 7, 9, 1.2)
    assert x.typename == "Real" { "promote of Int,Real,Int,Int,Real should be Real" }
}
