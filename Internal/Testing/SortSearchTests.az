package testing

use scope std

// --- sort ---

test "sort ascending" {
    var arr: [Int] = [3, 1, 4, 1, 5, 9, 2, 6]
    var sorted = sort<Int>(arr)
    assert sorted[0] == 1 { "sorted[0] should be 1" }
    assert sorted[1] == 1 { "sorted[1] should be 1" }
    assert sorted[2] == 2 { "sorted[2] should be 2" }
    assert sorted[3] == 3 { "sorted[3] should be 3" }
    assert sorted[4] == 4 { "sorted[4] should be 4" }
    assert sorted[5] == 5 { "sorted[5] should be 5" }
    assert sorted[6] == 6 { "sorted[6] should be 6" }
    assert sorted[7] == 9 { "sorted[7] should be 9" }
}

test "sort already sorted" {
    var arr: [Int] = [1, 2, 3]
    var sorted = sort<Int>(arr)
    assert sorted[0] == 1 { "sorted[0] should be 1" }
    assert sorted[1] == 2 { "sorted[1] should be 2" }
    assert sorted[2] == 3 { "sorted[2] should be 3" }
}

test "sort empty" {
    var arr: [Int] = [].fill<Int>(0)
    var sorted = sort<Int>(arr)
    assert sorted.length == 0 { "sorted empty array should be empty" }
}

// --- sortDescending ---

test "sortDescending" {
    var arr: [Int] = [3, 1, 2]
    var sorted = sortDescending<Int>(arr)
    assert sorted[0] == 3 { "desc sorted[0] should be 3" }
    assert sorted[1] == 2 { "desc sorted[1] should be 2" }
    assert sorted[2] == 1 { "desc sorted[2] should be 1" }
}

// --- isSorted ---

test "isSorted true" {
    var arr: [Int] = [1, 2, 3, 4, 5]
    assert isSorted<Int>(arr) { "should be sorted" }
}

test "isSorted false" {
    var arr: [Int] = [1, 3, 2]
    assert !isSorted<Int>(arr) { "should not be sorted" }
}

test "isSorted empty" {
    var arr: [Int] = [].fill<Int>(0)
    assert isSorted<Int>(arr) { "empty array should be sorted" }
}

test "isSorted single" {
    var arr: [Int] = [42]
    assert isSorted<Int>(arr) { "single element should be sorted" }
}

// --- reverse ---

test "reverse" {
    var arr: [Int] = [1, 2, 3, 4, 5]
    var rev = reverse<Int>(arr)
    assert rev[0] == 5 { "rev[0] should be 5" }
    assert rev[1] == 4 { "rev[1] should be 4" }
    assert rev[2] == 3 { "rev[2] should be 3" }
    assert rev[3] == 2 { "rev[3] should be 2" }
    assert rev[4] == 1 { "rev[4] should be 1" }
}

// --- linearSearch ---

test "linearSearch found" {
    var arr: [Int] = [10, 20, 30, 40, 50]
    assert linearSearch<Int>(arr, 30) == 2 { "linearSearch should find 30 at index 2" }
}

test "linearSearch not found" {
    var arr: [Int] = [10, 20, 30]
    assert linearSearch<Int>(arr, 99) == -1 { "linearSearch should return -1 for missing" }
}

// --- binarySearch ---

test "binarySearch found" {
    var arr: [Int] = [1, 3, 5, 7, 9, 11]
    assert binarySearch<Int>(arr, 7) == 3 { "binarySearch should find 7 at index 3" }
}

test "binarySearch not found" {
    var arr: [Int] = [1, 3, 5, 7, 9]
    assert binarySearch<Int>(arr, 4) == -1 { "binarySearch should return -1 for missing" }
}

test "binarySearch first element" {
    var arr: [Int] = [1, 2, 3]
    assert binarySearch<Int>(arr, 1) == 0 { "binarySearch should find first at 0" }
}

test "binarySearch last element" {
    var arr: [Int] = [1, 2, 3]
    assert binarySearch<Int>(arr, 3) == 2 { "binarySearch should find last at 2" }
}

// --- minOf & maxOf ---

test "minOf" {
    var arr: [Int] = [5, 3, 8, 1, 9]
    assert minOf<Int>(arr) == 1 { "minOf should be 1" }
}

test "maxOf" {
    var arr: [Int] = [5, 3, 8, 1, 9]
    assert maxOf<Int>(arr) == 9 { "maxOf should be 9" }
}

// --- count ---

test "count occurrences" {
    var arr: [Int] = [1, 2, 1, 3, 1, 4]
    assert count<Int>(arr, 1) == 3 { "count of 1 should be 3" }
    assert count<Int>(arr, 2) == 1 { "count of 2 should be 1" }
    assert count<Int>(arr, 99) == 0 { "count of 99 should be 0" }
}
