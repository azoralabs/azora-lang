package testing

use std.container

use zone std

test "tuple2 init" {
    fin tup = tupleOf(1, 2.0)
    assert tup.0 is Int && tup.0 == 1
    assert tup.1 is Real && tup.1 == 2.0
}

test "tuple2 explicit left init" {
    fin tup: Tuple<Int, Real> = tupleOf(1, 2.0)
    assert tup.0 is Int && tup.0 == 1
    assert tup.1 is Real && tup.1 == 2.0
}

test "tuple2 explicit right init" {
    fin tup = tupleOf<Int, Real>(1, 2.0)
    assert tup.0 is Int && tup.0 == 1
    assert tup.1 is Real && tup.1 == 2.0
}

test "tuple2 explicit init" {
    fin tup: Tuple<Int, Real> = tupleOf<Int, Real>(1, 2.0)
    assert tup.0 is Int && tup.0 == 1
    assert tup.1 is Real && tup.1 == 2.0
}

test "tuple3 init" {
    fin tup = tupleOf(1, 2.0, "3")
    assert tup.0 is Int && tup.0 == 1
    assert tup.1 is Real && tup.1 == 2.0
    assert tup.2 is String && tup.2 == "3"
}

func swap(t: Tuple<Int, Real>): Tuple<Real, Int> {
    return tupleOf(t.1, t.0)
}

test "tuple passed and returned from function" {
    fin r = swap(tupleOf(7, 9.0))
    assert r.0 is Real && r.0 == 9.0
    assert r.1 is Int && r.1 == 7
}

test "nested tuple access" {
    fin outer = tupleOf(tupleOf(1, 2), 3)
    fin inner = outer.0
    assert inner.0 == 1
    assert inner.1 == 2
    assert outer.1 == 3
}

test "tuple with explicit type args at call site" {
    fin tup = tupleOf<Int, Int>(10, 20)
    assert tup.0 == 10
    assert tup.1 == 20
}

test "tuple annotated and explicit together" {
    fin tup: Tuple<Bool, String> = tupleOf<Bool, String>(true, "yes")
    assert tup.0 == true
    assert tup.1 == "yes"
}
