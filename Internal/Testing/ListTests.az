package testing

use scope std

// --- Construction ---

test "List default construction" {
    var list = List<Int>()
    assert list.length == 0 { "new list should have length 0" }
    assert list.isEmpty { "new list should be empty" }
}

// --- Add & Length ---

test "List add and length" {
    var list = List<Int>()
    list.add(10)
    list.add(20)
    list.add(30)
    assert list.length == 3 { "length after 3 adds should be 3" }
    assert list.isNotEmpty { "list should not be empty" }
}

// --- Get ---

test "List get" {
    var list = List<String>()
    list.add("a")
    list.add("b")
    list.add("c")
    assert list.get(0) == "a" { "get(0) should be a" }
    assert list.get(1) == "b" { "get(1) should be b" }
    assert list.get(2) == "c" { "get(2) should be c" }
}

// --- First & Last ---

test "List first and last" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    assert list.first == 1 { "first should be 1" }
    assert list.last == 3 { "last should be 3" }
}

// --- Set ---

test "List set" {
    var list = List<Int>()
    list.add(10)
    list.add(20)
    list.add(30)
    list.set(1, 99)
    assert list.get(1) == 99 { "after set(1, 99), get(1) should be 99" }
    assert list.get(0) == 10 { "get(0) should still be 10" }
    assert list.get(2) == 30 { "get(2) should still be 30" }
}

// --- Insert ---

test "List insert at beginning" {
    var list = List<Int>()
    list.add(2)
    list.add(3)
    list.insert(0, 1)
    assert list.length == 3 { "length after insert should be 3" }
    assert list.get(0) == 1 { "inserted element at 0" }
    assert list.get(1) == 2 { "shifted element at 1" }
    assert list.get(2) == 3 { "shifted element at 2" }
}

test "List insert at middle" {
    var list = List<Int>()
    list.add(1)
    list.add(3)
    list.insert(1, 2)
    assert list.get(0) == 1 { "element at 0" }
    assert list.get(1) == 2 { "inserted element at 1" }
    assert list.get(2) == 3 { "shifted element at 2" }
}

test "List insert at end" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.insert(2, 3)
    assert list.get(2) == 3 { "inserted element at end" }
    assert list.length == 3 { "length after insert at end" }
}

// --- RemoveAt ---

test "List removeAt" {
    var list = List<Int>()
    list.add(10)
    list.add(20)
    list.add(30)
    fin removed = list.removeAt(1)
    assert removed == 20 { "removed element should be 20" }
    assert list.length == 2 { "length after remove should be 2" }
    assert list.get(0) == 10 { "first element unchanged" }
    assert list.get(1) == 30 { "second element shifted" }
}

// --- RemoveFirst & RemoveLast ---

test "List removeFirst" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    fin removed = list.removeFirst()
    assert removed == 1 { "removeFirst should return 1" }
    assert list.length == 2 { "length after removeFirst" }
    assert list.first == 2 { "new first should be 2" }
}

test "List removeLast" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    fin removed = list.removeLast()
    assert removed == 3 { "removeLast should return 3" }
    assert list.length == 2 { "length after removeLast" }
    assert list.last == 2 { "new last should be 2" }
}

// --- Clear ---

test "List clear" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    list.clear()
    assert list.length == 0 { "length after clear should be 0" }
    assert list.isEmpty { "list should be empty after clear" }
}

// --- Contains ---

test "List contains" {
    var list = List<String>()
    list.add("apple")
    list.add("banana")
    list.add("cherry")
    assert list.contains("banana") { "should contain banana" }
    assert !list.contains("grape") { "should not contain grape" }
}

// --- IndexOf & LastIndexOf ---

test "List indexOf" {
    var list = List<Int>()
    list.add(10)
    list.add(20)
    list.add(30)
    assert list.indexOf(20) == 1 { "indexOf 20 should be 1" }
    assert list.indexOf(99) == -1 { "indexOf missing element should be -1" }
}

test "List lastIndexOf" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(1)
    list.add(3)
    assert list.lastIndexOf(1) == 2 { "lastIndexOf 1 should be 2" }
    assert list.lastIndexOf(3) == 3 { "lastIndexOf 3 should be 3" }
    assert list.lastIndexOf(99) == -1 { "lastIndexOf missing should be -1" }
}

// --- ForEach ---

test "List forEach" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    var sum = 0
    list.forEach({ x -> sum += x })
    assert sum == 6 { "forEach sum should be 6" }
}

// --- Map ---

test "List map" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    var doubled = list.map({ x -> x * 2 })
    assert doubled.length == 3 { "mapped list length" }
    assert doubled.get(0) == 2 { "mapped element 0" }
    assert doubled.get(1) == 4 { "mapped element 1" }
    assert doubled.get(2) == 6 { "mapped element 2" }
}

// --- Filter ---

test "List filter" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    list.add(4)
    list.add(5)
    var evens = list.filter({ x -> x % 2 == 0 })
    assert evens.length == 2 { "filtered list length" }
    assert evens.get(0) == 2 { "first even" }
    assert evens.get(1) == 4 { "second even" }
}

// --- Any, All, None ---

test "List any" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    assert list.any({ x -> x > 2 }) { "any > 2 should be true" }
    assert !list.any({ x -> x > 10 }) { "any > 10 should be false" }
}

test "List all" {
    var list = List<Int>()
    list.add(2)
    list.add(4)
    list.add(6)
    assert list.all({ x -> x % 2 == 0 }) { "all even should be true" }
    list.add(7)
    assert !list.all({ x -> x % 2 == 0 }) { "all even should be false after adding 7" }
}

test "List none" {
    var list = List<Int>()
    list.add(1)
    list.add(3)
    list.add(5)
    assert list.none({ x -> x % 2 == 0 }) { "none even should be true" }
    assert !list.none({ x -> x > 2 }) { "none > 2 should be false" }
}

// --- Count ---

test "List count" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    list.add(4)
    list.add(5)
    assert list.count({ x -> x % 2 == 0 }) == 2 { "count of evens should be 2" }
    assert list.count({ x -> x > 0 }) == 5 { "count of positives should be 5" }
}

// --- SubList ---

test "List subList" {
    var list = List<Int>()
    list.add(10)
    list.add(20)
    list.add(30)
    list.add(40)
    list.add(50)
    var sub = list.subList(1, 4)
    assert sub.length == 3 { "subList length" }
    assert sub.get(0) == 20 { "subList element 0" }
    assert sub.get(1) == 30 { "subList element 1" }
    assert sub.get(2) == 40 { "subList element 2" }
}

// --- ToArray ---

test "List toArray" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    var arr = list.toArray()
    assert arr.length == 3 { "array length should be 3" }
    assert arr[0] == 1 { "array element 0" }
    assert arr[1] == 2 { "array element 1" }
    assert arr[2] == 3 { "array element 2" }
}

// --- Reversed ---

test "List reversed" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    var rev = list.reversed
    assert rev.length == 3 { "reversed length" }
    assert rev.get(0) == 3 { "reversed element 0" }
    assert rev.get(1) == 2 { "reversed element 1" }
    assert rev.get(2) == 1 { "reversed element 2" }
}

// --- ToString ---

test "List toString" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    assert list.toString() == "[1, 2, 3]" { "toString should be [1, 2, 3]" }
}

test "List toString empty" {
    var list = List<Int>()
    assert list.toString() == "[]" { "empty list toString should be []" }
}

// --- Edge Cases ---

test "List single element" {
    var list = List<Int>()
    list.add(42)
    assert list.first == 42 { "first of single element" }
    assert list.last == 42 { "last of single element" }
    assert list.length == 1 { "length of single element" }
    fin removed = list.removeFirst()
    assert removed == 42 { "remove single element" }
    assert list.isEmpty { "list empty after removing single element" }
}

test "List add many elements" {
    var list = List<Int>()
    for i in 0..99 {
        list.add(i)
    }
    assert list.length == 100 { "length after adding 100 elements" }
    assert list.first == 0 { "first element" }
    assert list.last == 99 { "last element" }
    assert list.get(50) == 50 { "middle element" }
}

test "List chained operations" {
    var list = List<Int>()
    list.add(1)
    list.add(2)
    list.add(3)
    list.add(4)
    list.add(5)

    var result = list
        .filter({ x -> x % 2 != 0 })
        .map({ x -> x * 10 })

    assert result.length == 3 { "chained result length" }
    assert result.get(0) == 10 { "chained result 0" }
    assert result.get(1) == 30 { "chained result 1" }
    assert result.get(2) == 50 { "chained result 2" }
}
