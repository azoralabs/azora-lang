package testing

use scope std

// --- Static Set Literals ---

test "Set literal basic" {
    fin s = ![1, 2, 3]
    assert s.length == 3 { "Set should have 3 elements" }
}

test "Set literal deduplication" {
    fin s = ![1, 2, 2, 3, 3, 3]
    assert s.length == 3 { "Set should deduplicate to 3 elements" }
}

test "Set literal empty" {
    fin s = ![]
    assert s.length == 0 { "Empty set should have 0 elements" }
    assert s.isEmpty { "Empty set should be empty" }
}

test "Set literal properties" {
    fin s = ![10, 20]
    assert s.length == 2 { "Set length should be 2" }
    assert s.isEmpty == false { "Non-empty set should not be empty" }
    assert s.isNotEmpty { "Non-empty set should be not empty" }
}

test "Set literal with explicit type" {
    fin s: ![Int] = ![4, 5, 6]
    assert s.length == 3 { "Typed set should have 3 elements" }
}

test "Set literal display string" {
    fin s = ![1, 2, 3]
    fin str = toString(s)
    assert str == "![1, 2, 3]" { "Set display should be ![1, 2, 3], got " + str }
}

// --- Static Map Literals ---

test "Map literal basic" {
    fin m = ["a": 1, "b": 2, "c": 3]
    assert m.length == 3 { "Map should have 3 entries" }
}

test "Map literal empty" {
    fin m = [:]
    assert m.length == 0 { "Empty map should have 0 entries" }
    assert m.isEmpty { "Empty map should be empty" }
}

test "Map literal properties" {
    fin m = ["x": 10, "y": 20]
    assert m.length == 2 { "Map length should be 2" }
    assert m.isEmpty == false { "Non-empty map should not be empty" }
    assert m.isNotEmpty { "Non-empty map should be not empty" }
}

test "Map literal index access" {
    fin m = ["hello": 42, "world": 99]
    assert m["hello"] == 42 { "Map[hello] should be 42" }
    assert m["world"] == 99 { "Map[world] should be 99" }
}

test "Map literal keys and values" {
    fin m = ["a": 1, "b": 2]
    fin k = m.keys
    fin v = m.values
    assert k.length == 2 { "Keys should have 2 elements" }
    assert v.length == 2 { "Values should have 2 elements" }
}

test "Map literal with explicit type" {
    fin m: [String:Int] = ["x": 100]
    assert m.length == 1 { "Typed map should have 1 entry" }
    assert m["x"] == 100 { "Typed map[x] should be 100" }
}

test "Map literal display string" {
    fin m = ["a": 1]
    fin str = toString(m)
    assert str == "{a: 1}" { "Map display should be {a: 1}, got " + str }
}

// --- Array literal to List coercion ---

test "Array literal to List coercion" {
    var list: List<Int> = [1, 2, 3]
    assert list.length == 3 { "List should start with 3 elements" }
    assert list.get(0) == 1 { "List[0] should be 1" }
    assert list.get(1) == 2 { "List[1] should be 2" }
    assert list.get(2) == 3 { "List[2] should be 3" }
}

test "Array literal to List coercion - add grows" {
    var list: List<Int> = [1, 2, 3]
    list.add(4)
    assert list.length == 4 { "List should grow to 4 after add" }
    assert list.get(3) == 4 { "List[3] should be 4" }
}

// --- Array .fill(count, value) ---

test "Array fill creates filled array" {
    fin arr = [].fill(5, 0)
    assert arr[0] == 0 { "arr[0] should be 0" }
    assert arr[4] == 0 { "arr[4] should be 0" }
}

test "Array fill with non-zero value" {
    fin arr = [].fill(3, 42)
    assert arr[0] == 42 { "arr[0] should be 42" }
    assert arr[1] == 42 { "arr[1] should be 42" }
    assert arr[2] == 42 { "arr[2] should be 42" }
}

test "Array fill with large count" {
    var board = [].fill(200, 0)
    board[199] = 7
    assert board[0] == 0 { "board[0] should be 0" }
    assert board[199] == 7 { "board[199] should be 7" }
}

test "Array fill is mutable" {
    var arr = [].fill(4, 1)
    arr[2] = 99
    assert arr[2] == 99 { "arr[2] should be 99 after mutation" }
    assert arr[0] == 1 { "arr[0] should still be 1" }
}

// --- Set literal to Set pack coercion ---

test "Set literal to Set pack coercion" {
    var s: Set<Int> = ![1, 2, 3]
    assert s.length == 3 { "Set pack should start with 3 elements" }
}

test "Set literal to Set pack coercion - add grows" {
    var s: Set<Int> = ![1, 2, 3]
    s.add(4)
    assert s.length == 4 { "Set pack should grow to 4 after add" }
}

test "Set literal to Set pack coercion - add dedup" {
    var s: Set<Int> = ![1, 2, 3]
    s.add(2)
    assert s.length == 3 { "Set pack should stay at 3 after adding duplicate" }
}

// --- Map literal to Map pack coercion ---

test "Map literal to Map pack coercion" {
    var m: Map<String, Int> = ["a": 1, "b": 2]
    assert m.length == 2 { "Map pack should start with 2 entries" }
}

test "Map literal to Map pack coercion - put grows" {
    var m: Map<String, Int> = ["a": 1, "b": 2]
    m.put("c", 3)
    assert m.length == 3 { "Map pack should grow to 3 after put" }
}
