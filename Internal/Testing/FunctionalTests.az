package testing

use scope std

// --- Identity ---

test "identity int" {
    assert identity<Int>(42) == 42 { "identity should return same value" }
}

test "identity string" {
    assert identity<String>("hello") == "hello" { "identity should return same string" }
}

// --- Map ---

test "map doubles" {
    fin arr = [1, 2, 3, 4, 5]
    fin result = map<Int>(arr, { x -> x * 2 })
    assert result.length == 5 { "map preserves length" }
    assert result[0] == 2 { "1 * 2 = 2" }
    assert result[4] == 10 { "5 * 2 = 10" }
}

test "map squares" {
    fin arr = [1, 2, 3]
    fin result = map<Int>(arr, { x -> x * x })
    assert result[0] == 1 { "1^2" }
    assert result[1] == 4 { "2^2" }
    assert result[2] == 9 { "3^2" }
}

// --- Filter ---

test "filter even" {
    fin arr = [1, 2, 3, 4, 5, 6]
    fin result = filter<Int>(arr, { x -> x % 2 == 0 })
    assert result.length == 3 { "3 even numbers" }
    assert result[0] == 2 { "first even" }
    assert result[1] == 4 { "second even" }
    assert result[2] == 6 { "third even" }
}

test "filter none match" {
    fin arr = [1, 3, 5]
    fin result = filter<Int>(arr, { x -> x % 2 == 0 })
    assert result.length == 0 { "no evens" }
}

// --- Reduce ---

test "reduce sum" {
    fin arr = [1, 2, 3, 4, 5]
    fin result = reduce<Int>(arr, 0, { acc, x -> acc + x })
    assert result == 15 { "sum 1..5 = 15" }
}

test "reduce product" {
    fin arr = [1, 2, 3, 4]
    fin result = reduce<Int>(arr, 1, { acc, x -> acc * x })
    assert result == 24 { "product 1..4 = 24" }
}

test "reduce max" {
    fin arr = [3, 1, 4, 1, 5, 9, 2, 6]
    fin result = reduce<Int>(arr, arr[0], { acc, x -> if x > acc { x } else { acc } })
    assert result == 9 { "max should be 9" }
}

// --- Any / All / None ---

test "any positive" {
    fin arr = [-1, -2, 3, -4]
    assert any<Int>(arr, { x -> x > 0 }) == true { "any positive" }
}

test "any none match" {
    fin arr = [-1, -2, -3]
    assert any<Int>(arr, { x -> x > 0 }) == false { "no positives" }
}

test "all positive" {
    fin arr = [1, 2, 3]
    assert all<Int>(arr, { x -> x > 0 }) == true { "all positive" }
}

test "all not all positive" {
    fin arr = [1, -2, 3]
    assert all<Int>(arr, { x -> x > 0 }) == false { "not all positive" }
}

test "none negative" {
    fin arr = [1, 2, 3]
    assert none<Int>(arr, { x -> x < 0 }) == true { "no negatives" }
}

test "none has negative" {
    fin arr = [1, -2, 3]
    assert none<Int>(arr, { x -> x < 0 }) == false { "has negative" }
}

// --- Take and Drop ---

test "take first 3" {
    fin arr = [10, 20, 30, 40, 50]
    fin result = take<Int>(arr, 3)
    assert result.length == 3 { "take 3 elements" }
    assert result[0] == 10 { "first" }
    assert result[2] == 30 { "third" }
}

test "take more than length" {
    fin arr = [1, 2]
    fin result = take<Int>(arr, 10)
    assert result.length == 2 { "take clamps to length" }
}

test "drop first 2" {
    fin arr = [10, 20, 30, 40, 50]
    fin result = drop<Int>(arr, 2)
    assert result.length == 3 { "drop 2 from 5" }
    assert result[0] == 30 { "first after drop" }
    assert result[2] == 50 { "last" }
}

// --- Zip ---

test "zip equal length" {
    fin a = [1, 2, 3]
    fin b = [4, 5, 6]
    fin result = zip<Int>(a, b)
    assert result.length == 3 { "3 pairs" }
    assert result[0][0] == 1 { "pair 0, first" }
    assert result[0][1] == 4 { "pair 0, second" }
    assert result[2][0] == 3 { "pair 2, first" }
    assert result[2][1] == 6 { "pair 2, second" }
}

// --- Fill and Generate ---

test "fill array" {
    fin result = fill<Int>(0, 5)
    assert result.length == 5 { "fill creates 5 elements" }
    assert result[0] == 0 { "all zeros" }
    assert result[4] == 0 { "all zeros" }
}

test "generate array" {
    fin result = generate<Int>(5, { i -> i * i })
    assert result.length == 5 { "5 elements" }
    assert result[0] == 0 { "0^2" }
    assert result[1] == 1 { "1^2" }
    assert result[2] == 4 { "2^2" }
    assert result[3] == 9 { "3^2" }
    assert result[4] == 16 { "4^2" }
}

// --- CountWhere ---

test "countWhere even" {
    fin arr = [1, 2, 3, 4, 5, 6]
    fin result = countWhere<Int>(arr, { x -> x % 2 == 0 })
    assert result == 3 { "3 even numbers" }
}

// --- FindOr ---

test "findOr found" {
    fin arr = [10, 20, 30, 40]
    fin result = findOr<Int>(arr, { x -> x > 25 }, -1)
    assert result == 30 { "first > 25 is 30" }
}

test "findOr not found" {
    fin arr = [10, 20, 30]
    fin result = findOr<Int>(arr, { x -> x > 100 }, -1)
    assert result == -1 { "default when not found" }
}
