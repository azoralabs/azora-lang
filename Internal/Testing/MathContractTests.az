package testing

use scope std

// --- Math with contracts ---

test "abs positive" {
    assert abs<Int>(5) == 5 { "abs of positive" }
}

test "abs negative" {
    assert abs<Int>(-5) == 5 { "abs of negative" }
}

test "abs zero" {
    assert abs<Int>(0) == 0 { "abs of zero" }
}

test "clamp within range" {
    assert clamp<Int>(5, 0, 10) == 5 { "within range" }
}

test "clamp below" {
    assert clamp<Int>(-5, 0, 10) == 0 { "clamped to lo" }
}

test "clamp above" {
    assert clamp<Int>(15, 0, 10) == 10 { "clamped to hi" }
}

test "sign positive" {
    assert sign<Int>(42) == 1 { "positive sign" }
}

test "sign negative" {
    assert sign<Int>(-42) == -1 { "negative sign" }
}

test "sign zero" {
    assert sign<Int>(0) == 0 { "zero sign" }
}

// --- Extra math with contracts ---

test "pow basic" {
    assert pow<Int>(2, 10) == 1024 { "2^10 = 1024" }
    assert pow<Int>(3, 0) == 1 { "3^0 = 1" }
    assert pow<Int>(5, 3) == 125 { "5^3 = 125" }
}

test "factorial basic" {
    assert factorial<Int>(0) == 1 { "0!" }
    assert factorial<Int>(1) == 1 { "1!" }
    assert factorial<Int>(5) == 120 { "5!" }
    assert factorial<Int>(10) == 3628800 { "10!" }
}

test "gcd basic" {
    assert gcd<Int>(12, 8) == 4 { "gcd(12,8) = 4" }
    assert gcd<Int>(15, 5) == 5 { "gcd(15,5) = 5" }
    assert gcd<Int>(17, 13) == 1 { "coprime" }
}

test "lcm basic" {
    assert lcm<Int>(4, 6) == 12 { "lcm(4,6) = 12" }
    assert lcm<Int>(3, 5) == 15 { "lcm(3,5) = 15" }
}

test "isEven and isOdd" {
    assert isEven<Int>(4) == true { "4 is even" }
    assert isEven<Int>(3) == false { "3 is not even" }
    assert isOdd<Int>(3) == true { "3 is odd" }
    assert isOdd<Int>(4) == false { "4 is not odd" }
}

test "sum array" {
    assert sum<Int>([1, 2, 3, 4, 5]) == 15 { "sum 1..5" }
}

test "product array" {
    assert product<Int>([1, 2, 3, 4]) == 24 { "product 1..4" }
}

test "fib sequence" {
    assert fib<Int>(0) == 0 { "fib(0)" }
    assert fib<Int>(1) == 1 { "fib(1)" }
    assert fib<Int>(2) == 1 { "fib(2)" }
    assert fib<Int>(10) == 55 { "fib(10)" }
    assert fib<Int>(20) == 6765 { "fib(20)" }
}
