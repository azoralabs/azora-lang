package testing

task simpleTask(): Int { suspend 10; return 42 }
task addAsync(a: Int, b: Int): Int { suspend 5; return a + b }
task<T> identityTask(x: T): T { suspend 1; return x }

test "Task returns value" { assert simpleTask() == 42 { "should return 42" } }
test "Task with params" { assert addAsync(3, 7) == 10 { "should return 10" } }
test "Suspend in hook" { suspend 10 }
test "Async and await" {
    fin t = async { 100 }
    fin r = await(t)
    assert r == 100 { "await should return 100" }
}
test "Multiple async tasks" {
    fin t1 = async { 1 }
    fin t2 = async { 2 }
    assert await(t1) + await(t2) == 3 { "concurrent sum should be 3" }
}
test "Launch executes" {
    var x = 0
    launch { x = 99 }
    suspend 50
    assert x == 99 { "launch should have set x" }
}
test "Generic task Int" { assert identityTask(42) == 42 { "identity Int" } }
test "Generic task String" { assert identityTask("hi") == "hi" { "identity String" } }
