module testing

flow range(n: Int): Int {
    for i in 0..n {
        yield i
    }
}

flow empty(): Int {
}

flow single(): Int {
    yield 42
}

test "Flow basic for-in iteration" {
    var sum = 0
    async for x in range(3) {
        sum += x
    }
    assert sum == 6 { "sum of range(3) should be 6, got $sum" }
}

test "Flow collect to array" {
    fin arr = range(3).collect()
    assert arr.length == 4 { "range(3).collect() should have 4 elements, got ${arr.length}" }
    assert arr[0] == 0 { "arr[0] should be 0" }
    assert arr[1] == 1 { "arr[1] should be 1" }
    assert arr[2] == 2 { "arr[2] should be 2" }
    assert arr[3] == 3 { "arr[3] should be 3" }
}

test "Flow early break" {
    var last = -1
    async for x in range(100) {
        last = x
        if x == 2 {
            break
        }
    }
    assert last == 2 { "break should stop at 2, got $last" }
}

test "Flow empty iteration" {
    var count = 0
    async for x in empty() {
        count += 1
    }
    assert count == 0 { "empty flow should iterate 0 times, got $count" }
}

test "Flow single value" {
    fin arr = single().collect()
    assert arr.length == 1 { "single().collect() should have 1 element" }
    assert arr[0] == 42 { "single value should be 42" }
}

test "Flow indexed for-in" {
    var indices = 0
    async for x in range(2) with idx {
        indices += idx
    }
    assert indices == 3 { "sum of indices for range(2) should be 3, got $indices" }
}

flow fibonacci(n: Int): Int {
    var a = 0
    var b = 1
    for i in 0..n {
        yield a
        fin temp = a + b
        a = b
        b = temp
    }
}

test "Flow fibonacci" {
    fin fibs = fibonacci(6).collect()
    assert fibs[0] == 0 { "fib(0) should be 0" }
    assert fibs[1] == 1 { "fib(1) should be 1" }
    assert fibs[2] == 1 { "fib(2) should be 1" }
    assert fibs[3] == 2 { "fib(3) should be 2" }
    assert fibs[4] == 3 { "fib(4) should be 3" }
    assert fibs[5] == 5 { "fib(5) should be 5" }
    assert fibs[6] == 8 { "fib(6) should be 8" }
}

flow<T> identityFlow(items: [T]): T {
    for x in items {
        yield x
    }
}

test "Generic flow identity" {
    fin ints = identityFlow<Int>([10, 20, 30]).collect()
    assert ints.length == 3 { "identity should yield 3 items" }
    assert ints[0] == 10 { "first should be 10" }
    assert ints[1] == 20 { "second should be 20" }
    assert ints[2] == 30 { "third should be 30" }
}
