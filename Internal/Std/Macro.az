export module std.macro

export import std.container.{list, set, tuple, array}

/**
 * @file Macro
 *
 * Pattern-driven `meta` macros available after `import std.macro`. Each macro
 * is a bare-name, top-level declaration invoked as `name!(…)`, `name![…]`, or
 * `name!{…}` (all three delimiters are equivalent). Arms match the invocation's
 * argument list: `[]` matches zero arguments; `[...$items]` matches one or more
 * and binds them, spliceable in the template via `...$items`.
 *
 * @since 0.0.4
 */

use friend zone std {
    /**
     * Builds an immutable [List].
     *
     * `vec![]` expands to `std::emptyList()`; `vec![1, 2, 3]` expands to
     * `std::listOf(1, 2, 3)`.
     */
    meta vec {
        [] => std::emptyList()
        [...$items] => std::listOf(...$items)
    }

    /**
     * Builds an immutable [Set].
     *
     * `set![1, 2, 3]` expands to `std::setOf(1, 2, 3)`.
     */
    meta set {
        [...$items] => std::setOf(...$items)
    }

    /**
     * Builds a structural [Tuple].
     *
     * `tup!(1, "two", 3.0)` expands to `std::tupleOf(1, "two", 3.0)`.
     */
    meta tup {
        [...$items] => std::tupleOf(...$items)
    }

    /**
     * Builds a fixed [Array].
     *
     * `arr![1, 2, 3]` expands to `std::arrayOf(1, 2, 3)`.
     */
    meta arr {
        [...$items] => std::arrayOf(...$items)
    }

    meta map {
        [] // implement it
    }

    // So we can say "fin x: [Int; 3] = arr![1, 2, 3]", "fin x: [Int] = vec![1, 2, 3]", "fin x: {Int} = set![1, 2, 3]"
    // "fin x: [String: Int] = map!["1": 1, "2": 2]", "fin x: (Real, String) = tup!(2.0, "Hi")"
    // no more array [T], no more tuple (T1, T2) inside compiler, no more [1, 2, 3] array literal and (1, "2") tuple literal inside compiler
    // we will use this meta type
    meta type {
        [T; N] => std::Array<T, N>
        [T] => std::List<T>
        {T} => std::Set<T>
        [K: V] => std::Map<K, V>
        (...T) => std::Tuple<...T>
    }
}
