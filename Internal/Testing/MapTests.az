package testing

use zone std

// --- Construction ---

test "Map default construction" {
    var map = Map<String, Int>()
    assert map.length == 0 { "new map should have length 0" }
    assert map.isEmpty { "new map should be empty" }
}

// --- Put & Get ---

test "Map put and get" {
    var map = Map<String, Int>()
    map.put("a", 1)
    map.put("b", 2)
    map.put("c", 3)
    assert map.length == 3 { "length after 3 puts should be 3" }
    assert map.get("a") == 1 { "get a should be 1" }
    assert map.get("b") == 2 { "get b should be 2" }
    assert map.get("c") == 3 { "get c should be 3" }
}

test "Map put replaces existing key" {
    var map = Map<String, Int>()
    map.put("x", 10)
    map.put("x", 20)
    assert map.length == 1 { "duplicate key should not increase length" }
    assert map.get("x") == 20 { "value should be updated to 20" }
}

// --- GetOrDefault ---

test "Map getOrDefault" {
    var map = Map<String, Int>()
    map.put("a", 1)
    assert map.getOrDefault("a", -1) == 1 { "existing key returns value" }
    assert map.getOrDefault("z", -1) == -1 { "missing key returns default" }
}

// --- Remove ---

test "Map remove" {
    var map = Map<String, Int>()
    map.put("a", 1)
    map.put("b", 2)
    map.put("c", 3)
    var removed: Int = map.remove("b")
    assert removed == 2 { "removed value should be 2" }
    assert map.length == 2 { "length after remove should be 2" }
    assert !map.containsKey("b") { "removed key should not exist" }
}

// --- ContainsKey & ContainsValue ---

test "Map containsKey" {
    var map = Map<String, Int>()
    map.put("hello", 42)
    assert map.containsKey("hello") { "should contain key hello" }
    assert !map.containsKey("world") { "should not contain key world" }
}

test "Map containsValue" {
    var map = Map<String, Int>()
    map.put("a", 10)
    map.put("b", 20)
    assert map.containsValue(10) { "should contain value 10" }
    assert !map.containsValue(99) { "should not contain value 99" }
}

// --- Clear ---

test "Map clear" {
    var map = Map<String, Int>()
    map.put("a", 1)
    map.put("b", 2)
    map.clear()
    assert map.length == 0 { "length after clear should be 0" }
    assert map.isEmpty { "map should be empty after clear" }
}

// --- ForEach ---

test "Map forEach" {
    var map = Map<String, Int>()
    map.put("a", 1)
    map.put("b", 2)
    map.put("c", 3)
    var total = 0
    map.forEach({ k, v -> total += v })
    assert total == 6 { "forEach sum of values should be 6" }
}

// --- Keys & Values ---

test "Map keys" {
    var map = Map<String, Int>()
    map.put("x", 1)
    map.put("y", 2)
    var k = map.keys()
    assert k.length == 2 { "keys length should be 2" }
    assert k[0] == "x" { "first key should be x" }
    assert k[1] == "y" { "second key should be y" }
}

test "Map values" {
    var map = Map<String, Int>()
    map.put("x", 10)
    map.put("y", 20)
    var v = map.values()
    assert v.length == 2 { "values length should be 2" }
    assert v[0] == 10 { "first value should be 10" }
    assert v[1] == 20 { "second value should be 20" }
}

// --- ToString ---

test "Map toString" {
    var map = Map<String, Int>()
    map.put("a", 1)
    assert map.isNotEmpty { "map should not be empty" }
}

test "Map toString empty" {
    var map = Map<String, Int>()
    assert map.toString == "{}" { "empty map toString should be {}" }
}
