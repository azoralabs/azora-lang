module testing

// --- ref parameter (read-only borrow) ---

pack Item {
    var value: Int = 0
    var name: String = ""
}

func readItem(ref item: Item): Int {
    return item.value
}

test "ref param read-only" {
    var x = Item(value: 42, name: "foo")
    assert readItem(ref x) == 42 { "ref param returns value" }
}

// --- mut parameter (mutable borrow) ---

func doubleValue(mut item: Item) {
    item.value *= 2
}

test "mut param mutable borrow" {
    var x = Item(value: 5, name: "bar")
    doubleValue(mut x)
    assert x.value == 10 { "mut param modified original" }
}

func swapValues(mut a: Item, mut b: Item) {
    var tmp = a.value
    a.value = b.value
    b.value = tmp
}

test "mut param swap" {
    var x = Item(value: 1)
    var y = Item(value: 2)
    swapValues(mut x, mut y)
    assert x.value == 2 { "x swapped" }
    assert y.value == 1 { "y swapped" }
}

// --- unsafe block ---

test "unsafe block executes" {
    var result = 0
    unsafe {
        result = 42
    }
    assert result == 42 { "unsafe block ran" }
}

// --- region block ---

test "region block executes" {
    var result = 0
    region(1024) { a ->
        result = 99
    }
    assert result == 99 { "region block ran" }
}

// --- ref param with pack methods ---

impl Item {
    func describe(): String { ref self ->
        "Item(${self.value}, ${self.name})"
    }
}

func getDescription(ref item: Item): String {
    return item.describe()
}

test "ref param method call" {
    var x = Item(value: 7, name: "test")
    assert getDescription(ref x) == "Item(7, test)" { "ref param method" }
}

// --- mut param with field assignment ---

func rename(mut item: Item, newName: String) {
    item.name = newName
}

test "mut param field assignment" {
    var x = Item(value: 1, name: "old")
    rename(mut x, newName: "new")
    assert x.name == "new" { "mut param renamed" }
}
