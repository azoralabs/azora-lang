package testing

use scope std

// --- Stack Construction ---

test "Stack default construction" {
    var stack = Stack<Int>()
    assert stack.length == 0 { "new stack should have length 0" }
    assert stack.isEmpty { "new stack should be empty" }
}

// --- Stack Push & Pop ---

test "Stack push and pop" {
    var stack = Stack<Int>()
    stack.push(1)
    stack.push(2)
    stack.push(3)
    assert stack.length == 3 { "length after 3 pushes should be 3" }
    fin top = stack.pop()
    assert top == 3 { "pop should return 3 (last pushed)" }
    assert stack.length == 2 { "length after pop should be 2" }
}

test "Stack LIFO order" {
    var stack = Stack<String>()
    stack.push("a")
    stack.push("b")
    stack.push("c")
    assert stack.pop() == "c" { "first pop should be c" }
    assert stack.pop() == "b" { "second pop should be b" }
    assert stack.pop() == "a" { "third pop should be a" }
    assert stack.isEmpty { "stack should be empty after all pops" }
}

// --- Stack Peek ---

test "Stack peek" {
    var stack = Stack<Int>()
    stack.push(42)
    stack.push(99)
    assert stack.peek() == 99 { "peek should return top element" }
    assert stack.length == 2 { "peek should not remove element" }
}

// --- Stack Clear ---

test "Stack clear" {
    var stack = Stack<Int>()
    stack.push(1)
    stack.push(2)
    stack.clear()
    assert stack.length == 0 { "length after clear should be 0" }
    assert stack.isEmpty { "stack should be empty after clear" }
}

// --- Stack ToString ---

test "Stack toString" {
    var stack = Stack<Int>()
    stack.push(1)
    stack.push(2)
    stack.push(3)
    assert stack.toString() == "[1, 2, 3]" { "toString should be [1, 2, 3]" }
}

// ==================
// Queue Tests
// ==================

// --- Queue Construction ---

test "Queue default construction" {
    var queue = Queue<Int>()
    assert queue.length == 0 { "new queue should have length 0" }
    assert queue.isEmpty { "new queue should be empty" }
}

// --- Queue Enqueue & Dequeue ---

test "Queue enqueue and dequeue" {
    var queue = Queue<Int>()
    queue.enqueue(1)
    queue.enqueue(2)
    queue.enqueue(3)
    assert queue.length == 3 { "length after 3 enqueues should be 3" }
    fin front = queue.dequeue()
    assert front == 1 { "dequeue should return 1 (first enqueued)" }
    assert queue.length == 2 { "length after dequeue should be 2" }
}

test "Queue FIFO order" {
    var queue = Queue<String>()
    queue.enqueue("a")
    queue.enqueue("b")
    queue.enqueue("c")
    assert queue.dequeue() == "a" { "first dequeue should be a" }
    assert queue.dequeue() == "b" { "second dequeue should be b" }
    assert queue.dequeue() == "c" { "third dequeue should be c" }
    assert queue.isEmpty { "queue should be empty after all dequeues" }
}

// --- Queue Peek ---

test "Queue peek" {
    var queue = Queue<Int>()
    queue.enqueue(42)
    queue.enqueue(99)
    assert queue.peek() == 42 { "peek should return front element" }
    assert queue.length == 2 { "peek should not remove element" }
}

// --- Queue Clear ---

test "Queue clear" {
    var queue = Queue<Int>()
    queue.enqueue(1)
    queue.enqueue(2)
    queue.clear()
    assert queue.length == 0 { "length after clear should be 0" }
    assert queue.isEmpty { "queue should be empty after clear" }
}

// --- Queue ToString ---

test "Queue toString" {
    var queue = Queue<Int>()
    queue.enqueue(1)
    queue.enqueue(2)
    queue.enqueue(3)
    assert queue.toString() == "[1, 2, 3]" { "toString should be [1, 2, 3]" }
}
