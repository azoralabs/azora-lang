module testing

// --- Compile-Time Code Execution (CTCE) Tests ---
// Tests using inline for, inline if, and compile-time folding

// --- Inline for loop ---

test "inline for generates values" {
    var sum = 0
    inline for i in 0..4 {
        sum += 1
    }
    assert sum == 5 { "inline for 0..4 should iterate 5 times" }
}

test "inline for with computation" {
    var total = 0
    inline for i in 0..2 {
        total += ($i + 1) * 10
    }
    assert total == 60 { "inline for sum: 10+20+30 = 60" }
}

// --- Compile-time constant folding ---

test "constant folding arithmetic" {
    fin a = 3 * 4 + 5
    assert a == 17 { "3 * 4 + 5 should be 17" }
}

test "constant folding nested" {
    fin a = 2
    fin b = 3
    fin c = a * b + a
    assert c == 8 { "2 * 3 + 2 should be 8" }
}

test "constant folding string" {
    fin greeting = "Hello" + ", " + "World!"
    assert greeting == "Hello, World!" { "string concatenation" }
}

test "constant folding boolean" {
    fin a = true && false
    fin b = true || false
    assert a == false { "true && false" }
    assert b == true { "true || false" }
}

// --- Type operations ---

test "compile-time type name" {
    fin x = 42
    fin t = x.typename
    assert t == "Int" { "typename should be Int" }
}

test "compile-time string typename" {
    fin s = "hello"
    fin t = s.typename
    assert t == "String" { "typename should be String" }
}

test "compile-time bool typename" {
    fin b = true
    fin t = b.typename
    assert t == "Bool" { "typename should be Bool" }
}

test "compile-time char typename" {
    fin c = 'a'
    fin t = c.typename
    assert t == "Char" { "typename should be Char" }
}

// --- Complex compile-time patterns ---

test "nested constant expressions" {
    fin base = 10
    fin scale = 3
    fin offset = 7
    fin result = base * scale + offset
    assert result == 37 { "10 * 3 + 7 = 37" }
}

test "compile-time range" {
    var count = 0
    for i in 0..9 {
        count += 1
    }
    assert count == 10 { "0..9 should have 10 elements" }
}

test "compile-time array creation" {
    fin arr = [1, 2, 3, 4, 5]
    assert arr.length == 5 { "array should have 5 elements" }
    assert arr[0] == 1 { "first element" }
    assert arr[4] == 5 { "last element" }
}

// --- Multiple inline blocks ---

test "multiple inline for" {
    var a = 0
    var b = 0
    inline for i in 0..2 {
        a += 1
    }
    inline for j in 0..3 {
        b += 1
    }
    assert a == 3 { "first inline for count" }
    assert b == 4 { "second inline for count" }
}
