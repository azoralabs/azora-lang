package testing

use zone std

// =====================================================================
// Component types for testing
// =====================================================================

pack Position { var x: Real = 0.0; var y: Real = 0.0 }
pack Velocity { var dx: Real = 0.0; var dy: Real = 0.0 }
pack Health { var current: Int = 100; var max: Int = 100 }
pack Name { var value: String = "" }
pack Score { var points: Int = 0 }
pack Enemy {}
pack Player {}

pack DamageEvent { var targetId: Int = 0; var amount: Int = 0 }
pack SpawnEvent { var x: Real = 0.0; var y: Real = 0.0 }

// =====================================================================
// Local Entity, Phase (non-generic stdlib types not available in tests)
// =====================================================================

pack Entity {
    fin id: Int = -1
    fin generation: Int = 0
}

impl ctor for Entity

impl oper== for Entity { ref self, rhs ->
    self.id == rhs.id && self.generation == rhs.generation
}

impl oper!= for Entity { ref self, rhs ->
    self.id != rhs.id || self.generation != rhs.generation
}

impl Entity {
    prop isValid: Bool = id >= 0

    func toString(): String { ref self ->
        "Entity(" + toString(self.id) + "v" + toString(self.generation) + ")"
    }
}

enum Phase { Startup, First, PreUpdate, OnUpdate, PostUpdate, Last, FixedUpdate }

// =====================================================================
// Local World pack (uses List<T> from stdlib for dynamic storage)
// =====================================================================

pack World {
    var gens: List<Int> = List<Int>()
    var alive: List<Bool> = List<Bool>()
    var names: List<String> = List<String>()
    var parents: List<Int> = List<Int>()
    var childCnts: List<Int> = List<Int>()
    var prefabs: List<Bool> = List<Bool>()
    var freeIds: List<Int> = List<Int>()
    var sysNames: List<String> = List<String>()
    var sysEnabled: List<Bool> = List<Bool>()
    var entityCount: Int = 0
    var aliveCount: Int = 0
    var tick: Int = 0
    var totalTime: Real = 0.0
    var fixedTimestep: Real = 0.016
    var fixedAccumulator: Real = 0.0
    var systemCount: Int = 0
    var deferring: Bool = false
}

impl World {
    func spawn(): Entity {
        var id: Int = 0
        var gen: Int = 0
        if freeIds.isNotEmpty {
            id = freeIds.last
            freeIds.removeLast()
            gen = gens.get(id) + 1
            gens.set(id, gen)
            alive.set(id, true)
            names.set(id, "")
            parents.set(id, -1)
            childCnts.set(id, 0)
            prefabs.set(id, false)
        } else {
            id = entityCount
            gen = 0
            gens.add(0)
            alive.add(true)
            names.add("")
            parents.add(-1)
            childCnts.add(0)
            prefabs.add(false)
            self.entityCount = entityCount + 1
        }
        self.aliveCount = aliveCount + 1
        return Entity(id: id, generation: gen)
    }

    func spawnNamed(name: String): Entity {
        fin entity = self.spawn()
        names.set(entity.id, name)
        return entity
    }

    func despawn(entity: Entity) {
        if 0 > entity.id || entity.id >= entityCount { return }
        if !alive.get(entity.id) { return }
        if gens.get(entity.id) != entity.generation { return }
        alive.set(entity.id, false)
        names.set(entity.id, "")
        self.aliveCount = aliveCount - 1
        fin pid = parents.get(entity.id)
        if pid >= 0 && entityCount > pid {
            childCnts.set(pid, childCnts.get(pid) - 1)
        }
        parents.set(entity.id, -1)
        childCnts.set(entity.id, 0)
        freeIds.add(entity.id)
    }

    func isAlive(entity: Entity): Bool {
        if 0 > entity.id || entity.id >= entityCount { return false }
        return alive.get(entity.id) && gens.get(entity.id) == entity.generation
    }

    func isAliveById(entityId: Int): Bool {
        if 0 > entityId || entityId >= entityCount { return false }
        return alive.get(entityId)
    }

    func getGeneration(entityId: Int): Int {
        if 0 > entityId || entityId >= entityCount { return 0 }
        return gens.get(entityId)
    }

    func getEntity(entityId: Int): Entity {
        return Entity(id: entityId, generation: gens.get(entityId))
    }

    func count(): Int { return aliveCount }

    func setName(entity: Entity, name: String) {
        if !self.isAlive(entity) { return }
        names.set(entity.id, name)
    }

    func getName(entity: Entity): String {
        if !self.isAlive(entity) { return "" }
        return names.get(entity.id)
    }

    func lookup(name: String): Entity {
        var i = 0
        while i < entityCount {
            if alive.get(i) && names.get(i) == name {
                return Entity(id: i, generation: gens.get(i))
            }
            i += 1
        }
        return Entity(id: -1, generation: 0)
    }

    func setParent(child: Entity, parent: Entity) {
        if !self.isAlive(child) || !self.isAlive(parent) { return }
        fin oldPid = parents.get(child.id)
        if oldPid >= 0 && entityCount > oldPid {
            childCnts.set(oldPid, childCnts.get(oldPid) - 1)
        }
        parents.set(child.id, parent.id)
        childCnts.set(parent.id, childCnts.get(parent.id) + 1)
    }

    func getParent(entity: Entity): Entity {
        if !self.isAlive(entity) { return Entity(id: -1, generation: 0) }
        fin pid = parents.get(entity.id)
        if 0 > pid { return Entity(id: -1, generation: 0) }
        return Entity(id: pid, generation: gens.get(pid))
    }

    func hasParent(entity: Entity): Bool {
        if !self.isAlive(entity) { return false }
        return parents.get(entity.id) >= 0
    }

    func getChildCount(entity: Entity): Int {
        if !self.isAlive(entity) { return 0 }
        return childCnts.get(entity.id)
    }

    func removeParent(entity: Entity) {
        if !self.isAlive(entity) { return }
        fin pid = parents.get(entity.id)
        if pid >= 0 && entityCount > pid {
            childCnts.set(pid, childCnts.get(pid) - 1)
        }
        parents.set(entity.id, -1)
    }

    func forEachChild(parent: Entity, callback: (Entity) -> Unit) {
        if !self.isAlive(parent) { return }
        var i = 0
        while i < entityCount {
            if alive.get(i) && parents.get(i) == parent.id {
                callback(Entity(id: i, generation: gens.get(i)))
            }
            i += 1
        }
    }

    func markPrefab(entity: Entity) {
        if !self.isAlive(entity) { return }
        prefabs.set(entity.id, true)
    }

    func isPrefab(entity: Entity): Bool {
        if !self.isAlive(entity) { return false }
        return prefabs.get(entity.id)
    }

    func addSystem(name: String, phase: Phase, callback: (Real) -> Unit) {
        sysNames.add(name)
        sysEnabled.add(true)
        self.systemCount = systemCount + 1
    }

    func enableSystem(name: String) {
        var i = 0
        while i < systemCount {
            if sysNames.get(i) == name { sysEnabled.set(i, true); return }
            i += 1
        }
    }

    func disableSystem(name: String) {
        var i = 0
        while i < systemCount {
            if sysNames.get(i) == name { sysEnabled.set(i, false); return }
            i += 1
        }
    }

    func isSystemEnabled(name: String): Bool {
        var i = 0
        while i < systemCount {
            if sysNames.get(i) == name { return sysEnabled.get(i) }
            i += 1
        }
        return false
    }

    func progress(deltaTime: Real) {
        self.tick = tick + 1
        self.totalTime = totalTime + deltaTime
        self.fixedAccumulator = fixedAccumulator + deltaTime
    }

    func consumeFixedStep(): Bool {
        if fixedAccumulator >= fixedTimestep {
            self.fixedAccumulator = fixedAccumulator - fixedTimestep
            return true
        }
        return false
    }

    func setFixedTimestep(timestep: Real) {
        self.fixedTimestep = timestep
    }
}

// =====================================================================
// Entity Lifecycle
// =====================================================================

test "Entity default construction" {
    fin e = Entity()
    assert e.id == -1 { "default entity id should be -1" }
    assert e.generation == 0 { "default generation should be 0" }
    assert !e.isValid { "default entity should not be valid" }
}

test "Entity explicit construction" {
    fin e = Entity(id: 5, generation: 2)
    assert e.id == 5 { "entity id" }
    assert e.generation == 2 { "generation" }
    assert e.isValid { "entity should be valid" }
}

test "Entity equality" {
    fin a = Entity(id: 1, generation: 0)
    fin b = Entity(id: 1, generation: 0)
    fin c = Entity(id: 1, generation: 1)
    assert a == b { "same should be equal" }
    assert a != c { "different gen should not be equal" }
}

test "Entity toString" {
    fin e = Entity(id: 3, generation: 1)
    assert e.toString() == "Entity(3v1)" { "toString format" }
}

// =====================================================================
// World - Spawn & Despawn
// =====================================================================

test "World spawn single entity" {
    var world = World()
    fin e = world.spawn()
    assert e.id == 0 { "first entity id" }
    assert e.generation == 0 { "first generation" }
    assert world.isAlive(e) { "spawned entity alive" }
    assert world.count() == 1 { "alive count" }
}

test "World spawn multiple entities" {
    var world = World()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    fin e2 = world.spawn()
    assert e0.id == 0 { "first id" }
    assert e1.id == 1 { "second id" }
    assert e2.id == 2 { "third id" }
    assert world.count() == 3 { "alive count" }
}

test "World despawn entity" {
    var world = World()
    fin e = world.spawn()
    world.despawn(e)
    assert !world.isAlive(e) { "dead after despawn" }
    assert world.count() == 0 { "count after despawn" }
}

test "World entity recycling" {
    var world = World()
    fin e0 = world.spawn()
    world.despawn(e0)
    fin e1 = world.spawn()
    assert e1.id == 0 { "recycled id" }
    assert e1.generation == 1 { "recycled generation" }
    assert world.isAlive(e1) { "recycled entity alive" }
    assert !world.isAlive(e0) { "old handle stale" }
}

test "World stale handle detection" {
    var world = World()
    fin e0 = world.spawn()
    world.despawn(e0)
    fin e1 = world.spawn()
    assert !world.isAlive(e0) { "stale handle" }
    assert world.isAlive(e1) { "new handle alive" }
}

test "World isAlive invalid entity" {
    var world = World()
    assert !world.isAlive(Entity(id: -1, generation: 0)) { "negative id" }
    assert !world.isAlive(Entity(id: 999, generation: 0)) { "out of range" }
}

// =====================================================================
// Storage<T> - Basic Operations
// =====================================================================

test "Storage default construction" {
    var positions = Storage<Position>()
    assert positions.length == 0 { "new storage empty" }
    assert positions.isEmpty { "isEmpty" }
}

test "Storage insert and get" {
    var world = World()
    var positions = Storage<Position>()
    fin e = world.spawn()
    positions.insert(e, Position(x: 10.0, y: 20.0))
    assert positions.has(e) { "has component" }
    fin pos = positions.get(e)
    assert pos.x == 10.0 { "x" }
    assert pos.y == 20.0 { "y" }
}

test "Storage insert replaces existing" {
    var world = World()
    var positions = Storage<Position>()
    fin e = world.spawn()
    positions.insert(e, Position(x: 1.0, y: 2.0))
    positions.insert(e, Position(x: 3.0, y: 4.0))
    assert positions.length == 1 { "no duplicate" }
    assert positions.get(e).x == 3.0 { "updated x" }
}

test "Storage getOrDefault" {
    var world = World()
    var health = Storage<Health>()
    fin e = world.spawn()
    fin h = health.getOrDefault(e, Health(current: 50, max: 50))
    assert h.current == 50 { "default" }
    health.insert(e, Health(current: 75, max: 100))
    assert health.getOrDefault(e, Health(current: 50, max: 50)).current == 75 { "actual" }
}

test "Storage remove" {
    var world = World()
    var positions = Storage<Position>()
    fin e = world.spawn()
    positions.insert(e, Position(x: 5.0, y: 5.0))
    fin removed = positions.remove(e)
    assert removed { "remove true" }
    assert positions.length == 0 { "empty after remove" }
    assert !positions.has(e) { "no component after remove" }
}

test "Storage multiple entities" {
    var world = World()
    var positions = Storage<Position>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    fin e2 = world.spawn()
    positions.insert(e0, Position(x: 0.0, y: 0.0))
    positions.insert(e1, Position(x: 1.0, y: 1.0))
    positions.insert(e2, Position(x: 2.0, y: 2.0))
    assert positions.length == 3 { "three components" }
    assert positions.get(e1).x == 1.0 { "e1 x" }
}

test "Storage remove last element" {
    var world = World()
    var positions = Storage<Position>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    positions.insert(e0, Position(x: 0.0, y: 0.0))
    positions.insert(e1, Position(x: 1.0, y: 1.0))
    positions.remove(e1)
    assert positions.length == 1 { "one after remove" }
    assert positions.has(e0) { "e0 still present" }
    assert !positions.has(e1) { "e1 removed" }
}

test "Storage forEach" {
    var world = World()
    var positions = Storage<Position>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    positions.insert(e0, Position(x: 10.0, y: 0.0))
    positions.insert(e1, Position(x: 20.0, y: 0.0))
    var sum = 0.0
    positions.forEach({ entity, pos -> sum += pos.x })
    assert sum == 30.0 { "forEach sum" }
}

test "Storage change detection" {
    var world = World()
    var positions = Storage<Position>()
    fin e = world.spawn()
    positions.insert(e, Position(x: 1.0, y: 2.0))
    assert positions.wasAdded(e) { "added flag" }
    positions.clearTracking()
    positions.insert(e, Position(x: 3.0, y: 4.0))
    assert positions.wasChanged(e) { "changed flag" }
    assert !positions.wasAdded(e) { "not added after update" }
}

// =====================================================================
// Resource<T>
// =====================================================================

test "Resource default not present" {
    var score = Resource<Score>()
    assert !score.exists { "not set" }
}

test "Resource set and get" {
    var score = Resource<Score>()
    score.set(Score(points: 100))
    assert score.exists { "exists" }
    assert score.get().points == 100 { "value" }
}

test "Resource getOrDefault" {
    var score = Resource<Score>()
    assert score.getOrDefault(Score(points: -1)).points == -1 { "default" }
    score.set(Score(points: 42))
    assert score.getOrDefault(Score(points: -1)).points == 42 { "actual" }
}

test "Resource modify" {
    var score = Resource<Score>()
    score.set(Score(points: 10))
    fin result = score.modify({ s -> Score(points: s.points + 5) })
    assert result.points == 15 { "modified" }
}

// =====================================================================
// EventQueue<T>
// =====================================================================

test "EventQueue send and drain" {
    var events = EventQueue<DamageEvent>()
    events.send(DamageEvent(targetId: 1, amount: 10))
    events.send(DamageEvent(targetId: 2, amount: 20))
    assert events.length == 2 { "two events" }
    var total = 0
    events.drain({ evt -> total += evt.amount })
    assert total == 30 { "total damage" }
    assert events.isEmpty { "empty after drain" }
}

test "EventQueue peek" {
    var events = EventQueue<DamageEvent>()
    events.send(DamageEvent(targetId: 5, amount: 50))
    assert events.peek(0).amount == 50 { "peeked amount" }
}

// =====================================================================
// Query Functions - each
// =====================================================================

test "each iterates alive entities" {
    var world = World()
    var positions = Storage<Position>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    fin e2 = world.spawn()
    positions.insert(e0, Position(x: 1.0, y: 0.0))
    positions.insert(e1, Position(x: 2.0, y: 0.0))
    positions.insert(e2, Position(x: 3.0, y: 0.0))
    var sum = 0.0
    each<Position>(positions, world, { entity, pos -> sum += pos.x })
    assert sum == 6.0 { "each sum" }
}

test "each skips dead entities" {
    var world = World()
    var positions = Storage<Position>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    positions.insert(e0, Position(x: 10.0, y: 0.0))
    positions.insert(e1, Position(x: 20.0, y: 0.0))
    world.despawn(e0)
    var sum = 0.0
    each<Position>(positions, world, { entity, pos -> sum += pos.x })
    assert sum == 20.0 { "skip dead" }
}

// =====================================================================
// Query Functions - each2
// =====================================================================

test "each2 iterates entities with both components" {
    var world = World()
    var positions = Storage<Position>()
    var velocities = Storage<Velocity>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    fin e2 = world.spawn()
    positions.insert(e0, Position(x: 0.0, y: 0.0))
    positions.insert(e1, Position(x: 0.0, y: 0.0))
    positions.insert(e2, Position(x: 0.0, y: 0.0))
    velocities.insert(e0, Velocity(dx: 1.0, dy: 0.0))
    velocities.insert(e2, Velocity(dx: 3.0, dy: 0.0))
    var count = 0
    var dxSum = 0.0
    each2<Position, Velocity>(positions, velocities, world, { entity, pos, vel ->
        count += 1
        dxSum += vel.dx
    })
    assert count == 2 { "both components" }
    assert dxSum == 4.0 { "sum dx" }
}

// =====================================================================
// Filtered Queries - eachWithout
// =====================================================================

test "eachWithout excludes entities" {
    var world = World()
    var positions = Storage<Position>()
    var enemies = Storage<Enemy>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    fin e2 = world.spawn()
    positions.insert(e0, Position(x: 1.0, y: 0.0))
    positions.insert(e1, Position(x: 2.0, y: 0.0))
    positions.insert(e2, Position(x: 3.0, y: 0.0))
    enemies.insert(e1, Enemy())
    var sum = 0.0
    eachWithout<Position, Enemy>(positions, enemies, world, { entity, pos ->
        sum += pos.x
    })
    assert sum == 4.0 { "sum excluding enemy" }
}

// =====================================================================
// Count Queries
// =====================================================================

test "countWith counts alive entities" {
    var world = World()
    var positions = Storage<Position>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    positions.insert(e0, Position())
    positions.insert(e1, Position())
    assert countWith<Position>(positions, world) == 2 { "two" }
    world.despawn(e1)
    assert countWith<Position>(positions, world) == 1 { "one after despawn" }
}

// =====================================================================
// Spawn Helpers
// =====================================================================

test "spawnWith creates entity with component" {
    var world = World()
    var positions = Storage<Position>()
    fin e = spawnWith<Position>(world, positions, Position(x: 42.0, y: 99.0))
    assert world.isAlive(e) { "alive" }
    assert positions.has(e) { "has position" }
    assert positions.get(e).x == 42.0 { "x" }
}

test "copyComponent copies data" {
    var world = World()
    var positions = Storage<Position>()
    fin src = world.spawn()
    fin dst = world.spawn()
    positions.insert(src, Position(x: 7.0, y: 8.0))
    copyComponent<Position>(positions, src, dst)
    assert positions.has(dst) { "copied" }
    assert positions.get(dst).x == 7.0 { "x" }
}

// =====================================================================
// World - Naming
// =====================================================================

test "World naming and lookup" {
    var world = World()
    fin e = world.spawnNamed("Player")
    assert world.getName(e) == "Player" { "name" }
    fin found = world.lookup("Player")
    assert found.isValid { "found" }
    assert found.id == e.id { "correct entity" }
}

test "World lookup missing" {
    var world = World()
    assert !world.lookup("missing").isValid { "not found" }
}

// =====================================================================
// World - Hierarchy
// =====================================================================

test "World parent-child" {
    var world = World()
    fin parent = world.spawn()
    fin child = world.spawn()
    world.setParent(child, parent)
    assert world.hasParent(child) { "has parent" }
    assert world.getParent(child).id == parent.id { "parent id" }
    assert world.getChildCount(parent) == 1 { "child count" }
}

test "World removeParent" {
    var world = World()
    fin parent = world.spawn()
    fin child = world.spawn()
    world.setParent(child, parent)
    world.removeParent(child)
    assert !world.hasParent(child) { "no parent" }
    assert world.getChildCount(parent) == 0 { "zero children" }
}

test "World forEachChild" {
    var world = World()
    fin parent = world.spawn()
    fin c0 = world.spawn()
    fin c1 = world.spawn()
    world.spawn()
    world.setParent(c0, parent)
    world.setParent(c1, parent)
    var count = 0
    world.forEachChild(parent, { child -> count += 1 })
    assert count == 2 { "two children" }
}

test "World despawn decrements child count" {
    var world = World()
    fin parent = world.spawn()
    fin child = world.spawn()
    world.setParent(child, parent)
    world.despawn(child)
    assert world.getChildCount(parent) == 0 { "zero after despawn" }
}

// =====================================================================
// World - Prefabs
// =====================================================================

test "World prefab" {
    var world = World()
    fin prefab = world.spawn()
    world.markPrefab(prefab)
    assert world.isPrefab(prefab) { "is prefab" }
    assert !world.isPrefab(world.spawn()) { "normal not prefab" }
}

// =====================================================================
// World - Simulation
// =====================================================================

test "World progress" {
    var world = World()
    world.progress(0.016)
    assert world.tick == 1 { "tick" }
    assert world.totalTime == 0.016 { "time" }
    world.progress(0.016)
    assert world.tick == 2 { "tick 2" }
}

test "World consumeFixedStep" {
    var world = World()
    world.setFixedTimestep(0.01)
    world.progress(0.025)
    var steps = 0
    while world.consumeFixedStep() { steps += 1 }
    assert steps == 2 { "two steps" }
}

// =====================================================================
// World - Systems
// =====================================================================

test "World addSystem" {
    var world = World()
    world.addSystem("test", Phase.OnUpdate, { dt -> })
    assert world.systemCount == 1 { "one system" }
}

test "World enable disable system" {
    var world = World()
    world.addSystem("move", Phase.OnUpdate, { dt -> })
    world.disableSystem("move")
    assert !world.isSystemEnabled("move") { "disabled" }
    world.enableSystem("move")
    assert world.isSystemEnabled("move") { "enabled" }
}

// =====================================================================
// Tag Components
// =====================================================================

test "Tag components with each2" {
    var world = World()
    var positions = Storage<Position>()
    var enemies = Storage<Enemy>()
    var players = Storage<Player>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    fin e2 = world.spawn()
    positions.insert(e0, Position(x: 0.0, y: 0.0))
    positions.insert(e1, Position(x: 1.0, y: 1.0))
    positions.insert(e2, Position(x: 2.0, y: 2.0))
    enemies.insert(e0, Enemy())
    enemies.insert(e2, Enemy())
    players.insert(e1, Player())
    var enemyCount = 0
    each2<Position, Enemy>(positions, enemies, world, { entity, pos, tag -> enemyCount += 1 })
    assert enemyCount == 2 { "two enemies" }
}

// =====================================================================
// Movement System Pattern
// =====================================================================

test "Movement system with each2" {
    var world = World()
    var positions = Storage<Position>()
    var velocities = Storage<Velocity>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    positions.insert(e0, Position(x: 0.0, y: 0.0))
    positions.insert(e1, Position(x: 10.0, y: 10.0))
    velocities.insert(e0, Velocity(dx: 1.0, dy: 2.0))
    velocities.insert(e1, Velocity(dx: -1.0, dy: 0.5))
    fin dt = 0.016
    each2<Position, Velocity>(positions, velocities, world, { entity, pos, vel ->
        positions.insert(entity, Position(x: pos.x + vel.dx * dt, y: pos.y + vel.dy * dt))
    })
    assert positions.get(e0).x == 0.016 { "e0 moved x" }
    assert positions.get(e1).x == 9.984 { "e1 moved x" }
}

// =====================================================================
// Damage System with Events
// =====================================================================

test "Damage system with events" {
    var world = World()
    var health = Storage<Health>()
    var damageEvents = EventQueue<DamageEvent>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    health.insert(e0, Health(current: 100, max: 100))
    health.insert(e1, Health(current: 80, max: 100))
    damageEvents.send(DamageEvent(targetId: e0.id, amount: 25))
    damageEvents.send(DamageEvent(targetId: e1.id, amount: 10))
    damageEvents.drain({ evt ->
        fin target = Entity(id: evt.targetId, generation: 0)
        if health.has(target) {
            fin h = health.get(target)
            health.insert(target, Health(current: h.current - evt.amount, max: h.max))
        }
    })
    assert health.get(e0).current == 75 { "e0 damage" }
    assert health.get(e1).current == 70 { "e1 damage" }
}

// =====================================================================
// Entity Reuse
// =====================================================================

test "Entity reuse after many cycles" {
    var world = World()
    var entity = world.spawn()
    for i in 0..9 {
        world.despawn(entity)
        entity = world.spawn()
    }
    assert entity.id == 0 { "same id" }
    assert entity.generation == 10 { "gen 10" }
    assert world.isAlive(entity) { "alive" }
}

// =====================================================================
// Edge Cases
// =====================================================================

test "Empty query" {
    var world = World()
    var positions = Storage<Position>()
    var count = 0
    each<Position>(positions, world, { entity, pos -> count += 1 })
    assert count == 0 { "nothing to iterate" }
}

test "Query with no matching pairs" {
    var world = World()
    var positions = Storage<Position>()
    var velocities = Storage<Velocity>()
    fin e0 = world.spawn()
    fin e1 = world.spawn()
    positions.insert(e0, Position())
    velocities.insert(e1, Velocity())
    var count = 0
    each2<Position, Velocity>(positions, velocities, world, { entity, pos, vel -> count += 1 })
    assert count == 0 { "no match" }
}

test "Storage count method" {
    var positions = Storage<Position>()
    assert positions.count() == 0 { "empty count" }
}
