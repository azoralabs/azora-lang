module testing

use zone std

// --- Construction ---

test "Channel default construction" {
    var ch = Channel<Int>()
    assert ch.isEmpty { "new channel should be empty" }
    assert !ch.isClosed { "new channel should not be closed" }
}

// --- Send & Receive ---

test "Channel send and receive" {
    var ch = Channel<Int>()
    ch.send(42)
    ch.send(99)
    assert ch.length == 2 { "channel length after 2 sends should be 2" }
    fin v1 = ch.receive()
    assert v1 == 42 { "first receive should be 42" }
    fin v2 = ch.receive()
    assert v2 == 99 { "second receive should be 99" }
    assert ch.isEmpty { "channel should be empty after receiving all" }
}

// --- TryReceive ---

test "Channel tryReceive with value" {
    var ch = Channel<Int>()
    ch.send(10)
    fin v = ch.tryReceive(-1)
    assert v == 10 { "tryReceive should return 10" }
}

test "Channel tryReceive empty" {
    var ch = Channel<Int>()
    fin v = ch.tryReceive(-1)
    assert v == -1 { "tryReceive on empty should return default" }
}

// --- Close ---

test "Channel close" {
    var ch = Channel<Int>()
    ch.send(1)
    ch.close()
    assert ch.isClosed { "channel should be closed" }
    fin v = ch.receive()
    assert v == 1 { "can still receive from closed channel" }
}

// --- FIFO Order ---

test "Channel FIFO order" {
    var ch = Channel<String>()
    ch.send("a")
    ch.send("b")
    ch.send("c")
    assert ch.receive() == "a" { "first should be a" }
    assert ch.receive() == "b" { "second should be b" }
    assert ch.receive() == "c" { "third should be c" }
}
